# Copy to .env.local for local development.
# Add the same values as Railway Variables for production.
# Do not commit real .env files.

# Browser-safe Supabase values. Use a publishable key if available.
# If Supabase only shows a legacy anon key, use NEXT_PUBLIC_SUPABASE_ANON_KEY instead.
# Do not expose service role keys to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key
# Railway Supabase plugin aliases are also accepted server-side:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_legacy_anon_key
# Required server-side for admin controls and maintenance scripts.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Railway self-hosted Supabase may expose SERVICE_ROLE_KEY; the app accepts it as a fallback.
# SERVICE_ROLE_KEY=your_service_role_key
# Optional input for npm run admin:load. The app reads admin access from public.admin_users.
# ADMIN_EMAILS=owner@example.com,ops@example.com

# Optional Redis pub/sub for external token quota listeners such as tty proxy.
# If unset, quota changes still succeed but no Redis event is published.
# TOKEN_QUOTA_REDIS_URL=redis://default:password@host:port
# TOKEN_QUOTA_REDIS_CHANNEL=2ndbrain:token-quota

# Solana billing. The treasury wallet receives Phantom payments; no user wallet keys are stored.
# Devnet is the default testing network. Switch to mainnet-beta only for live paid purchases.
# SOLANA_TREASURY_WALLET=your_solana_treasury_wallet_public_key
SOLANA_PAYMENT_NETWORK=devnet
# Optional custom RPC endpoint. Keep this server-side if it contains a provider key.
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_QUOTE_TTL_MS=300000

# Public app URL used for OAuth redirects.
# Railway also exposes RAILWAY_PUBLIC_DOMAIN, but setting this explicitly is preferred.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Avaturn iframe origin for the avatar creation step.
NEXT_PUBLIC_AVATURN_URL=https://2ndbrainceo.avaturn.dev

# Server-side local staging directory for downloaded Avaturn GLB files.
AVATAR_STORAGE_ROOT=storage/avatars

# Enable server-side GLB download diagnostics in local/staging logs.
AVATURN_DEBUG=false

# OpenClaw provisioning via clawmacdo and AWS Lightsail snapshot restore.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-southeast-1
OPENCLAW_LIGHTSAIL_SNAPSHOT_NAME=openclaw-claude-avatar
CLAWMACDO_TIMEOUT_MS=900000
CLAWMACDO_MAX_CONCURRENCY=1
CLAWMACDO_SPAWN_RETRIES=3
CLAWMACDO_SPAWN_RETRY_DELAY_MS=1500
CLAWMACDO_TOKIO_WORKER_THREADS=1
CLAWMACDO_RAYON_NUM_THREADS=1
OPENCLAW_AWS_CLI_TIMEOUT_MS=60000
OPENCLAW_INSTANCE_READY_TIMEOUT_MS=480000
OPENCLAW_SSH_READY_TIMEOUT_MS=600000
OPENCLAW_READY_POLL_MS=10000
OPENCLAW_POST_SSH_READY_DELAY_MS=15000
OPENCLAW_SSH_USER=openclaw
OPENCLAW_SSH_PORT=22
OPENCLAW_SSH_CONNECT_TIMEOUT_MS=30000
OPENCLAW_SSH_IDLE_TIMEOUT_MS=900000
OPENCLAW_SSH_MAX_SESSIONS_PER_USER=1
OPENCLAW_SSH_TOKEN_SECRET=change_me_to_a_long_random_secret
OPENCLAW_SSH_TOKEN_TTL_SECONDS=60

# Optional browser OAuth flow for Settings -> Google Workspace.
# Add this callback URL to the Google OAuth client's allowed redirect URIs:
# http://localhost:3000/api/openclaw/gws-auth/callback
# For Railway, also add https://your-public-domain/api/openclaw/gws-auth/callback.
# GWS_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# GWS_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
# Optional override. If unset, the app derives this from NEXT_PUBLIC_SITE_URL/request origin.
# GWS_OAUTH_REDIRECT_URI=http://localhost:3000/api/openclaw/gws-auth/callback
# GWS_OAUTH_SCOPES=https://www.googleapis.com/auth/drive https://www.googleapis.com/auth/spreadsheets https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/documents https://www.googleapis.com/auth/presentations https://www.googleapis.com/auth/tasks https://www.googleapis.com/auth/pubsub https://www.googleapis.com/auth/cloud-platform

# Required by clawmacdo remotion-avatar-setup.
OPENAI_API_KEY=your_openai_api_key

# OpenClaw Remotion and project generation settings.
OPENCLAW_REMOTION_APP_DIR=/home/openclaw/.openclaw/workspace/remotion-3d-AI-avatar
OPENCLAW_REMOTION_PORT=3002
OPENCLAW_CHAT_MODEL=openclaw
OPENCLAW_HOOKS_MAPPING=notify
OPENCLAW_AGENT_ID=main
OPENCLAW_LLM_WIKI_TIMEOUT_SECONDS=600
OPENCLAW_PROJECT_ROOT=/home/openclaw/.openclaw/workspace/2ndbrain-projects
OPENCLAW_LLM_WIKI_PROMPT_PATH=prompts/openclaw/llm-wiki.md
